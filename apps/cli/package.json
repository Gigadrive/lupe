{
  "name": "@gigadrive/lupe",
  "version": "0.1.0",
  "description": "lupe — platform- and provider-agnostic AI code review agent. BYO tokens or local Claude Code / Codex credentials.",
  "license": "MIT",
  "bin": {
    "lupe": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests",
    "check:exports": "publint --strict",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@effect/cli": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@gigadrive/lupe-core": "workspace:*",
    "@gigadrive/lupe-git": "workspace:*",
    "c12": "catalog:",
    "effect": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
