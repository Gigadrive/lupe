{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "singleQuote": true,
  "printWidth": 120,
  "trailingComma": "es5",
  "sortImports": {
    "internalPattern": ["@gigadrive/", "@repo/"]
  },
  "sortPackageJson": {},
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "renovate.json",
    "**/dist/**",
    "**/node_modules/**",
    "**/.turbo/**",
    "**/.git/**",
    "**/CHANGELOG.md",
    "**/.next/**",
    "**/.source/**",
    "**/next-env.d.ts",
    "**/*.mdx"
  ]
}
