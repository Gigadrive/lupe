{
  "name": "lupe",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check:exports": "turbo run check:exports",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "knip": "knip --cache",
    "effect:check": "effect-language-service check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@effect/language-service": "0.86.2",
    "@types/node": "24.7.1",
    "knip": "6.21.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "publint": "0.3.21",
    "tsdown": "0.22.3",
    "turbo": "2.10.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "packageManager": "pnpm@10.33.0"
}
