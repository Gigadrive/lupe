{
  "name": "@gigadrive/lupe-git",
  "version": "0.0.0",
  "description": "Diff parsing, hunk → (line, side) anchoring, read-only repo tools, and Qodo-style context compression for lupe.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests",
    "check:exports": "publint --strict",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@gigadrive/lupe-core": "workspace:*",
    "simple-git": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "effect": "catalog:"
  },
  "peerDependencies": {
    "effect": ">=3.21.0 <4"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
