{
  "name": "@gigadrive/lupe-github",
  "version": "0.0.0",
  "description": "GitHub transport for lupe: paginated diff fetch, batched review posting, sticky summary, and thread resolution.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests",
    "check:exports": "publint --strict",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@gigadrive/lupe-core": "workspace:*",
    "@gigadrive/lupe-git": "workspace:*",
    "@octokit/rest": "catalog:",
    "@octokit/plugin-retry": "catalog:",
    "@octokit/plugin-throttling": "catalog:",
    "@octokit/graphql": "catalog:"
  },
  "peerDependencies": {
    "effect": ">=3.21.0 <4"
  },
  "devDependencies": {
    "effect": "catalog:",
    "@types/node": "catalog:",
    "@repo/typescript-config": "workspace:*"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
