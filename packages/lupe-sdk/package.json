{
  "name": "@gigadrive/lupe-sdk",
  "version": "0.0.0",
  "description": "Embeddable, Promise-returning programmatic facade for the lupe AI code reviewer.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests",
    "check:exports": "publint --strict",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@gigadrive/lupe-core": "workspace:*",
    "@gigadrive/lupe-git": "workspace:*",
    "@gigadrive/lupe-github": "workspace:*",
    "effect": "catalog:"
  },
  "peerDependencies": {
    "zod": ">=4.0.0 <5"
  },
  "devDependencies": {
    "zod": "catalog:",
    "@types/node": "catalog:",
    "@repo/typescript-config": "workspace:*"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
